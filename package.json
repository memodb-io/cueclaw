{
  "name": "cueclaw",
  "version": "0.0.3",
  "description": "Orchestrate agent workflows with natural language. Natural language in, executable DAG out.",
  "type": "module",
  "bin": {
    "cueclaw": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts --format esm --target node22 --dts --clean",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "ai",
    "agent",
    "workflow",
    "orchestrator",
    "claude",
    "dag",
    "natural-language",
    "automation"
  ],
  "author": "memodb-io",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memodb-io/cueclaw.git"
  },
  "bugs": {
    "url": "https://github.com/memodb-io/cueclaw/issues"
  },
  "homepage": "https://github.com/memodb-io/cueclaw#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit $1"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@inkjs/ui": "^2.0.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "grammy": "^1.40.0",
    "ink": "5",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "nanoid": "^5.1.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "18",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
